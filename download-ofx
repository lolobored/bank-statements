#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="lolobored/bank-statements"

# Auto-update: if gh is available, check for a newer jar and script and download them
if command -v gh &>/dev/null; then
  LATEST_TAG=$(gh release view --repo "$REPO" --json tagName -q .tagName 2>/dev/null || true)
  if [ -n "$LATEST_TAG" ] && [ ! -f "$SCRIPT_DIR/bank-statements-${LATEST_TAG}.jar" ]; then
    echo "New version $LATEST_TAG available, updating..."
    gh release download "$LATEST_TAG" \
      --repo "$REPO" \
      --pattern "bank-statements-*.jar" \
      --dir "$SCRIPT_DIR" \
      --clobber
    JARS=( $(ls "$SCRIPT_DIR"/bank-statements-*.jar 2>/dev/null | sort -V) )
    COUNT=${#JARS[@]}
    if [ "$COUNT" -gt 1 ]; then
      for ((i=0; i<COUNT-1; i++)); do
        echo "Removed old jar: $(basename "${JARS[$i]}")"
        rm "${JARS[$i]}"
      done
    fi
    # Also update this script itself, then re-exec the new version
    if gh release download "$LATEST_TAG" \
        --repo "$REPO" \
        --pattern "download-ofx" \
        --dir "$SCRIPT_DIR" \
        --clobber 2>/dev/null; then
      chmod +x "$SCRIPT_DIR/download-ofx"
      echo "Script updated to $LATEST_TAG."
      exec "$SCRIPT_DIR/download-ofx" "$@"
    fi
    echo "Updated jar to $LATEST_TAG."
  fi
fi

JAR=$(ls "$SCRIPT_DIR"/bank-statements-*.jar 2>/dev/null | sort -V | tail -1)
if [ -z "$JAR" ]; then
  echo "No bank-statements jar found in $SCRIPT_DIR."
  echo "Install the GitHub CLI (gh) and re-run — the script will download the latest release automatically."
  exit 1
fi

JSON="$SCRIPT_DIR/banks.json"
OUTPUT="$HOME/Downloads"

# Use SDKMAN's current Java if available; otherwise rely on PATH
SDKMAN_JAVA="$HOME/.sdkman/candidates/java/current"
if [ -d "$SDKMAN_JAVA" ]; then
  export JAVA_HOME="$SDKMAN_JAVA"
  export PATH="$JAVA_HOME/bin:$PATH"
fi
if ! command -v java &>/dev/null; then
  echo "Java not found. Install Java 17+ via SDKMAN (https://sdkman.io) or any other method and ensure it is on your PATH."
  exit 1
fi

SESSION_FILE="$HOME/.bw_session"

# Load a previously stored session so we don't prompt every run
if [ -f "$SESSION_FILE" ]; then
  export BW_SESSION=$(cat "$SESSION_FILE")
fi

# Check vault status (uses BW_SESSION if set)
BW_STATUS=$(bw status 2>/dev/null | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

case "$BW_STATUS" in
  unauthenticated)
    echo "Not logged in to Bitwarden. Please run: bw login"
    exit 1
    ;;
  locked)
    echo "Unlocking Bitwarden vault..."
    export BW_SESSION=$(bw unlock --raw)
    echo "$BW_SESSION" > "$SESSION_FILE"
    chmod 600 "$SESSION_FILE"
    ;;
  unlocked)
    ;;
  *)
    echo "Could not determine Bitwarden status. Proceeding without unlock."
    ;;
esac

echo "Running $(basename "$JAR") with: $@"
java -jar "$JAR" --json="$JSON" --output="$OUTPUT" "$@"
